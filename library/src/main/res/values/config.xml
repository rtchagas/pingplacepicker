<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 0.007 USD per each (7.00 USD per 1000) -->
    <bool name="show_confirmation_photo">true</bool>

    <!-- Must enable Maps Static API in the key passed as mapsApiKey -->
    <bool name="show_confirmation_map">true</bool>

    <!-- The zoom level that is initially applied to the map -->
    <integer name="default_zoom">17</integer>

    <!-- Radius in meters around the map center used for both nearby search and
         the autocomplete location bias. -->
    <integer name="autocomplete_search_bias_radius">5000</integer>

    <!-- If true, the map will automatically center (pan) to the selected marker. -->
    <bool name="auto_center_on_marker_click">false</bool>

    <!-- Do not change this one. -->
    <bool name="show_card_search">true</bool>

</resources>
